import React, { useState, useEffect } from 'react';
import {
    fetchExams,
    fetchExamErrors,
    fetchPersonalGoals,
    fetchAllFlashcards
} from '../services/api';

interface MentorMessage {
    title: string;
    steps: string[];  // Passos numerados
    action?: string | null;
    tab?: string | null;
    emoji: string;
    urgent?: boolean;
}

const getMessageForContext = (
    activeTab: string,
    overdueFlashcards: number,
    overdueTopics: number,
    recentErrors: number,
    daysToExam: number | null,
    nextExamName: string | null,
    dailyTarget: number | null,
    goalProgress: number
): MentorMessage => {

    // ── DASHBOARD ──
    if (activeTab === 'dashboard') {
        if (overdueFlashcards > 0) return {
            emoji: '⚡',
            urgent: true,
            title: 'Flashcards vencidos!',
            steps: [
                `Clique em "Flashcards" na barra lateral esquerda`,
                'Clique no botão azul "Iniciar Revisão"',
                'Leia o frente do card e tente lembrar',
                'Clique em "Ver resposta" e avalie: Fácil, Normal ou Difícil',
                `Repita para os ${overdueFlashcards} cards vencidos`
            ],
            action: 'Ir para Flashcards agora →',
            tab: 'flashcards'
        };

        if (dailyTarget && goalProgress < 100)
            return {
                emoji: '✏️',
                title: 'Meta de questões',
                steps: [
                    `Resolva ${dailyTarget} questões em qualquer plataforma externa`,
                    'Volte aqui e clique em "Desempenho" na barra lateral',
                    'Role até "Metas Pessoais" no final da página',
                    `Clique no botão "+ X" ao lado da meta "Questões semanais"`,
                    'O progresso atualiza na hora e a barra acima sobe'
                ],
                action: 'Ir para Desempenho →',
                tab: 'performance'
            };

        if (recentErrors > 0) return {
            emoji: '📝',
            title: 'Erros para registrar',
            steps: [
                'Clique em "Caderno de Erros" na barra lateral',
                'Clique no botão escuro "Registrar Novo Erro"',
                'Selecione a especialidade clicando no botão',
                'Selecione o tema que aparece abaixo',
                'Escreva o subtema específico (ex: "Acalásia — critério manometria")',
                'Escolha a origem: Desatenção, Falta de Contato ou Cansaço',
                'Clique em "Finalizar Registro"'
            ],
            action: 'Ir para Caderno de Erros →',
            tab: 'errors'
        };

        return {
            emoji: '🌟',
            title: 'Tudo em dia!',
            steps: [
                'Clique em "Especialidades" na barra lateral',
                'Clique na especialidade que você estudou hoje',
                'Clique no tema estudado',
                'Registre sua performance (ex: 70 se acertou 70%)',
                'A próxima revisão é agendada automaticamente'
            ],
            action: 'Registrar estudo →',
            tab: 'topics'
        };
    }

    // ── ESPECIALIDADES ──
    if (activeTab === 'topics') return {
        emoji: '📚',
        title: 'Como registrar estudo',
        steps: [
            'Clique na especialidade para expandir a lista',
            'Encontre o tema que você estudou hoje',
            'Clique no nome do tema',
            'No campo que abre, coloque sua % de acertos (0 a 100)',
            'Clique em "Salvar" — a revisão é agendada automaticamente'
        ]
    };

    // ── REVISÕES ──
    if (activeTab === 'reviews') {
        if (overdueTopics > 0) return {
            emoji: '⏰',
            urgent: true,
            title: `${overdueTopics} revisão${overdueTopics > 1 ? 'ões' : ''} atrasada${overdueTopics > 1 ? 's' : ''}`,
            steps: [
                'Os cards em vermelho são os mais atrasados — comece por eles',
                'Clique no card do tema atrasado',
                'Revise o conteúdo no seu material',
                'Clique em "Avaliar" e coloque sua % de acertos atual',
                'O sistema recalcula o próximo intervalo automaticamente'
            ]
        };
        return {
            emoji: '✅',
            title: 'Revisões em dia',
            steps: [
                'Nenhuma revisão atrasada hoje — ótimo!',
                'Veja os temas agendados para os próximos dias',
                'Use esse tempo para fazer mais questões',
                'Clique em "Desempenho" para atualizar suas metas'
            ],
            action: 'Atualizar metas →',
            tab: 'performance'
        };
    }

    // ── FLASHCARDS ──
    if (activeTab === 'flashcards') {
        if (overdueFlashcards > 0) return {
            emoji: '🔥',
            urgent: true,
            title: `${overdueFlashcards} flashcard${overdueFlashcards > 1 ? 's' : ''} vencido${overdueFlashcards > 1 ? 's' : ''}`,
            steps: [
                'Procure o botão "Iniciar Revisão" ou "Revisar agora" na tela',
                'Leia o frente do card com atenção',
                'Tente lembrar a resposta ANTES de ver',
                'Clique em "Ver resposta"',
                'Avalie honestamente: Fácil (lembrou rápido), Normal (lembrou com esforço) ou Difícil (não lembrou)',
                `Repita para os ${overdueFlashcards} cards vencidos`
            ]
        };
        return {
            emoji: '😎',
            title: 'Flashcards em dia',
            steps: [
                'Todos os flashcards revisados — ótimo trabalho!',
                'Você pode criar novos flashcards nos seus temas de estudo',
                'Clique em "Especialidades" para registrar um novo estudo'
            ],
            action: 'Registrar estudo →',
            tab: 'topics'
        };
    }

    // ── CADERNO DE ERROS ──
    if (activeTab === 'errors') return {
        emoji: '🧠',
        title: 'Como registrar um erro',
        steps: [
            'Clique no botão escuro "Registrar Novo Erro" no topo',
            'Passo 1: clique na especialidade (ex: Clínica Médica)',
            'Passo 1: role a lista e clique no tema (ex: Síndrome Disfágica)',
            'Passo 1: clique em "Próximo passo"',
            'Passo 2: escreva o subtema ESPECÍFICO (ex: "Acalásia — critério manometria de alta resolução")',
            'Passo 2: clique na origem do erro (Desatenção, Falta de Contato ou Cansaço)',
            'Passo 2: clique em "Avançar"',
            'Passo 3: selecione em qual bloco estava a questão (1-25, 26-50, etc)',
            'Passo 3: escreva a nota clínica do que faltou',
            'Clique em "Finalizar Registro"'
        ]
    };

    // ── DESEMPENHO ──
    if (activeTab === 'performance') return {
        emoji: '📊',
        title: 'Como atualizar questões',
        steps: [
            'Role a página até encontrar "Metas Pessoais"',
            'Encontre a meta "Questões semanais"',
            'Clique no botão "+ 25" se fez 25 questões (ou + 10, + 5)',
            'O número atualiza na hora',
            'Faça o mesmo para metas de sono e exercício',
            'O Índice MedFlow aparece após 3 semanas de uso'
        ]
    };

    // ── SEMANA ──
    if (activeTab === 'weekly') return {
        emoji: '📅',
        title: 'Visão semanal',
        steps: [
            'Esta tela mostra temas agendados por dia',
            'Veja quais temas você precisa revisar cada dia desta semana',
            'Use para planejar seus estudos com antecedência',
            'Clique em "Revisões" para fazer as revisões de hoje'
        ],
        action: 'Fazer revisões de hoje →',
        tab: 'reviews'
    };

    // ── PALAVRAS CRUZADAS ──
    if (activeTab === 'crossword') return {
        emoji: '🎮',
        title: 'Fixe conceitos jogando',
        steps: [
            'Escolha um tema para gerar as palavras cruzadas',
            'Clique nas pistas e tente preencher as palavras',
            'Ideal para revisar após estudar um tema novo',
            'Quando terminar, volte para registrar o estudo'
        ],
        action: 'Registrar estudo →',
        tab: 'topics'
    };

    return {
        emoji: '🧙',
        title: 'Por onde começar',
        steps: [
            'Clique em "Especialidades" na barra lateral esquerda',
            'Expanda a especialidade que você estudou',
            'Registre o tema estudado com sua performance'
        ],
        action: 'Ir para Especialidades →',
        tab: 'topics'
    };
};

export function MentorGuide({ activeTab }: { activeTab: string }) {
    const [minimized, setMinimized] = useState(false);
    const [message, setMessage] = useState<MentorMessage | null>(null);
    const [prevTab, setPrevTab] = useState('');

    // Dados do mentor
    const [overdueFlashcards, setOverdueFlashcards] = useState(0);
    const [overdueTopics, setOverdueTopics] = useState(0);
    const [recentErrors, setRecentErrors] = useState(0);
    const [daysToExam, setDaysToExam] = useState<number | null>(null);
    const [nextExamName, setNextExamName] = useState<string | null>(null);
    const [dailyTarget, setDailyTarget] = useState<number | null>(null);
    const [goalProgress, setGoalProgress] = useState(0);

    // Quando muda de aba: reexpande e atualiza mensagem
    useEffect(() => {
        if (activeTab !== prevTab) {
            setMinimized(false);
            setPrevTab(activeTab);
        }
    }, [activeTab, prevTab]);

    // Buscar dados
    useEffect(() => {
        const loadData = async () => {
            try {
                const [exams, errors, goals, cards] = await Promise.all([
                    fetchExams(),
                    fetchExamErrors(),
                    fetchPersonalGoals(),
                    fetchAllFlashcards()
                ]);

                const now = new Date();

                // Flashcards vencidos
                const overdue = cards.filter(
                    (f: any) => f.next_review &&
                        new Date(f.next_review) < now &&
                        (f.repetition_level || 0) < 5
                ).length;
                setOverdueFlashcards(overdue);

                // Erros recentes (24h)
                const recent = errors.filter(
                    (e: any) =>
                        new Date(e.created_at) >
                        new Date(Date.now() - 86400000)
                ).length;
                setRecentErrors(recent);

                // Próxima prova
                const future = (exams as any[])
                    .filter((e: any) => new Date(e.date) >= now)
                    .sort((a: any, b: any) =>
                        new Date(a.date).getTime() -
                        new Date(b.date).getTime()
                    );

                if (future.length > 0) {
                    const diff = Math.ceil(
                        (new Date(future[0].date).getTime() - now.getTime()) / 86400000
                    );
                    setDaysToExam(diff);
                    setNextExamName(future[0].name);
                }

                // Meta do dia
                const studyGoal = goals.find(
                    (g: any) => g.category === 'estudo'
                );
                if (studyGoal) {
                    const target = Math.ceil(
                        (studyGoal.target_value - studyGoal.current_value) / 7
                    );
                    setDailyTarget(target);
                    setGoalProgress(
                        Math.round(
                            (studyGoal.current_value / studyGoal.target_value) * 100
                        ) || 0
                    );
                }
            } catch (e) {
                console.error('MentorGuide:', e);
            }
        };

        loadData();
        const interval = setInterval(loadData, 60000);
        return () => clearInterval(interval);
    }, []);

    // Calcular mensagem quando dados ou aba mudar
    useEffect(() => {
        const msg = getMessageForContext(
            activeTab,
            overdueFlashcards,
            overdueTopics,
            recentErrors,
            daysToExam,
            nextExamName,
            dailyTarget,
            goalProgress
        );
        setMessage(msg);
    }, [activeTab, overdueFlashcards, overdueTopics, recentErrors, daysToExam, nextExamName, dailyTarget, goalProgress]);

    const navigate = (tab: string) => {
        window.dispatchEvent(
            new CustomEvent('navigate', { detail: tab })
        );
    };

    if (!message) return null;

    // ESTADO MINIMIZADO
    if (minimized) {
        return (
            <div
                className="fixed bottom-6 right-6 z-[150] cursor-pointer"
                onClick={() => setMinimized(false)}
            >
                <div className={`w-16 h-16 bg-white rounded-full shadow-xl border-2 flex items-center justify-center text-3xl hover:scale-110 transition-transform ${message?.urgent
                    ? 'border-orange-400'
                    : 'border-emerald-300'
                    }`}>
                    🧙
                </div>
                {/* Ponto pulsante */}
                <div className={`absolute top-0 right-0 w-4 h-4 rounded-full border-2 border-white animate-pulse ${message?.urgent
                    ? 'bg-orange-500'
                    : 'bg-emerald-500'
                    }`} />
            </div>
        );
    }

    // ESTADO EXPANDIDO
    return (
        <div className="fixed bottom-6 right-6 z-[150] flex flex-col items-end gap-2 max-w-[300px]">
            {/* Balão de fala */}
            <div className={`bg-white rounded-2xl shadow-2xl p-4 relative w-[300px] border-2 transition-all duration-300 ${message.urgent
                ? 'border-orange-200'
                : 'border-emerald-100'
                }`}>
                {/* Indicador urgente */}
                {message.urgent && (
                    <div className="absolute -top-2 left-4 bg-orange-500 text-white text-[10px] font-black px-2 py-0.5 rounded-full uppercase tracking-wider">
                        Urgente
                    </div>
                )}

                {/* Botão minimizar */}
                <button
                    onClick={() => setMinimized(true)}
                    className="absolute top-2 right-2 w-6 h-6 rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition-colors text-sm flex items-center justify-center"
                >
                    ×
                </button>

                {/* Título */}
                <p className="text-sm font-black text-slate-800 mb-3 pr-6">
                    {message.emoji} {message.title}
                </p>

                {/* Passos numerados */}
                <div className="space-y-2 mb-3 max-h-52 overflow-y-auto pr-1 custom-scrollbar">
                    {message.steps.map((step, idx) => (
                        <div key={idx} className="flex items-start gap-2">
                            <div className="w-5 h-5 rounded-full bg-slate-800 text-white flex items-center justify-center text-[10px] font-black flex-shrink-0 mt-0.5">
                                {idx + 1}
                            </div>
                            <p className="text-xs text-slate-600 leading-snug flex-1">
                                {step}
                            </p>
                        </div>
                    ))}
                </div>

                {/* Botão de ação */}
                {message.action && message.tab && (
                    <button
                        onClick={() => navigate(message.tab!)}
                        className={`w-full py-2.5 rounded-xl text-xs font-black transition-colors flex items-center justify-center gap-1 ${message.urgent
                            ? 'bg-orange-500 hover:bg-orange-600 text-white'
                            : 'bg-slate-800 hover:bg-slate-700 text-white'
                            }`}
                    >
                        {message.action}
                    </button>
                )}

                {/* Seta do balão */}
                <div className="absolute -bottom-2.5 right-10 w-5 h-5 bg-white border-r-2 border-b-2 border-slate-100 rotate-45" />
            </div>

            {/* Personagem */}
            <div
                className="w-14 h-14 bg-white rounded-full shadow-xl border-2 flex items-center justify-center text-3xl cursor-pointer hover:scale-110 transition-transform self-end mr-2"
                style={{
                    borderColor: message.urgent ? '#F97316' : '#6EE7B7'
                }}
                onClick={() => setMinimized(true)}
                title="Minimizar"
            >
                🧙
            </div>
        </div>
    );
}

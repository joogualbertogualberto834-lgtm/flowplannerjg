import React, { useState, useEffect } from 'react';
import { format, startOfWeek, endOfWeek, eachDayOfInterval } from 'date-fns';
import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';
import { fetchExams, fetchPersonalGoals } from '../services/api';
import type { Topic } from '../services/types';

function cn(...inputs: ClassValue[]) {
    return twMerge(clsx(inputs));
}

interface WeeklyViewProps {
    topics: Topic[];
}

export function WeeklyView({ topics }: WeeklyViewProps) {
    const [exams, setExams] = useState<any[]>([]);
    const [goals, setGoals] = useState<any[]>([]);

    useEffect(() => {
        Promise.all([
            fetchExams(),
            fetchPersonalGoals()
        ]).then(([e, g]) => {
            setExams(e);
            setGoals(g);
        });
    }, []);

    const start = startOfWeek(new Date());
    const end = endOfWeek(new Date());
    const days = eachDayOfInterval({ start, end });

    const studyGoal = goals.find(g => g.category === 'estudo');
    const todayTarget = studyGoal
        ? Math.ceil((studyGoal.target_value - studyGoal.current_value) / 7)
        : null;

    return (
        <div className="max-w-5xl mx-auto">
            {todayTarget && (
                <div className="mb-6 p-4 bg-emerald-50 rounded-2xl border border-emerald-100 flex items-center justify-between">
                    <div>
                        <p className="text-[10px] font-bold text-emerald-600 uppercase tracking-widest">
                            Meta de hoje
                        </p>
                        <p className="text-2xl font-black text-emerald-800">
                            {todayTarget} questões
                        </p>
                    </div>
                    <div className="text-right">
                        <p className="text-[10px] text-emerald-600">
                            {studyGoal.current_value} / {studyGoal.target_value} na semana
                        </p>
                        <div className="w-32 h-2 bg-emerald-200 rounded-full mt-1 overflow-hidden">
                            <div
                                className="h-full bg-emerald-500 rounded-full"
                                style={{
                                    width: `${Math.min(100, (studyGoal.current_value / studyGoal.target_value) * 100)}%`
                                }}
                            />
                        </div>
                    </div>
                </div>
            )}

            <div className="grid grid-cols-1 md:grid-cols-7 gap-4">
                {days.map((day) => {
                    const dayKey = format(day, 'yyyy-MM-dd');
                    const examsOnDay = exams.filter(e =>
                        format(new Date(e.date), 'yyyy-MM-dd') === dayKey
                    );
                    const dayTopics = topics.filter(
                        (t) =>
                            t.next_review_date &&
                            format(new Date(t.next_review_date), 'yyyy-MM-dd') === dayKey,
                    );
                    const isToday = dayKey === format(new Date(), 'yyyy-MM-dd');

                    return (
                        <div
                            key={day.toString()}
                            className={cn(
                                'bg-white rounded-2xl border p-4 min-h-[200px] flex flex-col',
                                isToday ? 'border-emerald-500 ring-1 ring-emerald-500' : 'border-slate-200',
                            )}
                        >
                            <div className="mb-4">
                                <p className="text-[10px] font-bold text-slate-400 uppercase">
                                    {format(day, 'EEEE')}
                                </p>
                                <p
                                    className={cn(
                                        'text-lg font-bold',
                                        isToday ? 'text-emerald-600' : 'text-slate-800',
                                    )}
                                >
                                    {format(day, 'dd')}
                                </p>
                            </div>

                            <div className="flex-1 space-y-2">
                                {examsOnDay.map(exam => (
                                    <div key={exam.id} className="text-[10px] p-2 bg-blue-50 rounded-lg border border-blue-100 font-bold text-blue-700 mb-1">
                                        📋 {exam.name}
                                    </div>
                                ))}
                                {dayTopics.map((topic) => (
                                    <div
                                        key={topic.id}
                                        className="text-[10px] p-2 bg-slate-50 rounded-lg border border-slate-100 font-medium text-slate-600"
                                    >
                                        {topic.title}
                                    </div>
                                ))}
                                {dayTopics.length === 0 && (
                                    <div className="h-full flex items-center justify-center">
                                        <p className="text-[10px] text-slate-300 italic">Vazio</p>
                                    </div>
                                )}
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    );
}
